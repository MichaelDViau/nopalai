# =====================================================================
# NopalAI — Environment Variables
# Copy this file to .env.local and fill in your own values.
# Never commit .env.local to source control.
# =====================================================================

# ---- App ----
# Public base URL of the deployed app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Clerk (Authentication) ----
# https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ---- Supabase (Database) ----
# https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxx
# Server-only. NEVER expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxx

# ---- OpenRouter (AI Provider) ----
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
# Optional: model overrides (sensible defaults are in src/lib/modes.ts)
OPENROUTER_MODEL_FREE=deepseek/deepseek-chat
OPENROUTER_MODEL_PREMIUM=qwen/qwen-2.5-72b-instruct

# ---- Stripe (Subscriptions) ----
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
# Price ID for the Premium plan (99 MXN / month)
STRIPE_PREMIUM_PRICE_ID=price_xxxxxxxxxxxx
# Webhook signing secret (from `stripe listen` or dashboard webhook)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ---- Analytics ----
# PostHog — https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
